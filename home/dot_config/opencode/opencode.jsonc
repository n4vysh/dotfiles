{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5-fast",
  "theme": "tokyonight",
  "share": "disabled",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find": "allow",
      "find *": "allow",
      "find *-exec*": "ask",
      "find *-delete*": "ask",
      "fd": "allow",
      "fd *": "allow",
      "test *": "allow",
      "cat *": "allow",
      "pwd": "allow",
      "realpath *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "sed *-i*": "ask",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "diff *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git branch *-d*": "ask",
      "git branch *-m*": "ask",
      "git blame *": "allow",
      "git grep *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git ls-remote *": "allow",
      "git ls-tree *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git show-ref *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git shortlog": "allow",
      "git shortlog *": "allow",
      "git rev-parse *": "allow",
      "git rev-list *": "allow",
      "git remote -v": "allow",
      "git remote show": "allow",
      "git remote show *": "allow",
      "git merge-base *": "allow",
      "go fmt *": "allow",
      "go list *": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "gofumpt *": "allow",
      "na exec vitest *": "allow",
      "na exec prettier *": "allow",
      "na exec biome *": "allow",
      "nr test": "allow",
      "nr format": "allow",
      "nr fmt": "allow",
      "nl *": "allow",
      "sqlfluff fix *": "allow",
      "sqlfluff lint *": "allow",
      "aws * get-* *": "allow",
      "aws * describe-* *": "allow",
      "aws * list-* *": "allow",
      "aws logs start-query *": "allow",
      "aws logs filter-log-events *": "allow",
      "docker compose ps": "allow",
      "docker compose logs *": "allow",
      "kubectl auth whoami *": "allow",
      "kubectl auth can-i *": "allow",
      "kubectl config current-context": "allow",
      "kubectl logs *": "allow",
      "kubectl explain *": "allow",
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl rollout history *": "allow",
      "helm show *": "allow",
      "helm template *": "allow",
      "helmfile template": "allow",
      "helmfile template *": "allow",
      "terraform init -backend=false": "allow",
      "terragrunt init -backend=false": "allow",
      "terragrunt validate": "allow",
      "terragrunt validate *": "allow",
      "terragrunt output": "allow",
      "terragrunt output *": "allow",
      "terragrunt state list": "allow",
      "terragrunt state list *": "allow",
      "terragrunt show": "allow",
      "terragrunt show *": "allow",
      "terraform state list": "allow",
      "terraform state list *": "allow",
      "terraform show": "allow",
      "terraform show *": "allow",
      "terraform console": "allow",
      "terraform console *": "allow",
      "terraform fmt": "allow",
      "terraform fmt *": "allow",
      "terraform test": "allow",
      "terraform test *": "allow",
      "terraform validate": "allow",
      "terraform validate *": "allow",
      "terraform output": "allow",
      "terraform output *": "allow",
      "terraform-docs *": "allow",
      "tflint": "allow",
      "tflint *": "allow",
      "markdownlint-cli2 *": "allow",
      "glab --version": "allow",
      "glab auth status": "allow",
      "glab ci trace *": "allow",
      "glab ci status": "allow",
      "glab issue view *": "allow",
      "glab mr view": "allow",
      "glab mr view *": "allow",
      "glab mr diff": "allow",
      "glab mr diff *": "allow",
      "glab api \"/projects/*/merge_requests/*/notes?per_page=100\" --paginate": "allow",
      "glab api \"/projects/*/merge_requests/*/discussions?per_page=100\" --paginate": "allow",
      "glab api \"/projects/*/merge_requests/*/commits?per_page=100\" --paginate": "allow",
      "jq": "allow",
      "jq *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "sort": "allow",
      "uniq": "allow",
      "date": "allow",
      "date *": "allow",
      "which *": "allow"
    }
  },
  "keybinds": {
    "input_submit": "ctrl+s",
    "editor_open": "<leader>ctrl+e",
    "input_newline": "return",
    "session_child_cycle": "ctrl+meta+l",
    "session_child_cycle_reverse": "ctrl+meta+h"
  },
  "formatter": {
    // NOTE: run prettier even without package.json
    //       https://github.com/anomalyco/opencode/blob/v1.14.46/packages/opencode/src/format/formatter.ts#L37-L84
    "prettier-markdown": {
      "command": ["prettier", "--write", "$FILE"],
      "extensions": [".md"]
    },
    "yamlfmt": {
      "command": ["yamlfmt", "$FILE"],
      "extensions": [".yml", ".yaml"]
    }
  },
  "plugin": ["context-mode"],
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    },
    "aws-knowledge-server": {
      "enabled": false,
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "terraform-server": {
      "enabled": false,
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--name",
        "terraform-mcp-server",
        "hashicorp/terraform-mcp-server:0.5.0"
      ]
    },
    // "aws-example-dev-server": {
    //   "enabled": false,
    //   "type": "local",
    //   "command": [
    //     "mcp-proxy-for-aws",
    //     "https://aws-mcp.us-east-1.api.aws/mcp",
    //     "--disable-telemetry"
    //   ],
    //   "environment": {
    //     "AWS_PROFILE": "example-dev",
    //     "AWS_REGION": "ap-northeast-1"
    //   }
    // },
    // "kubernetes-example-dev-server": {
    //   "enabled": false,
    //   "type": "local",
    //   "command": [
    //     "kubernetes-mcp-server",
    //     "--read-only"
    //   ],
    //   "environment": {
    //     "KUBECONFIG": "{env:HOME}/.kube/configs/example-dev"
    //   }
    // },
    // // ```sh
    // // gopass insert envs/mcp-grafana/example-dev/GRAFANA_SERVICE_ACCOUNT_TOKEN
    // // ```
    // "grafana-example-dev-server": {
    //   "enabled": false,
    //   "type": "local",
    //   "command": [
    //     "gopass",
    //     "env",
    //     "envs/mcp-grafana/example-dev",
    //     "mcp-grafana",
    //     "--disable-write",
    //     "-t",
    //     "stdio"
    //   ],
    //   "environment": {
    //     "GRAFANA_ORG_ID": "1",
    //     "GRAFANA_URL": "https://example.com"
    //   }
    // },
    "context7-server": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "microsandbox-server": {
      "enabled": false,
      "type": "local",
      "command": ["microsandbox-mcp"]
    }
  }
}
