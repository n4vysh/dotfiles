{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol", // flagship model
  "small_model": "openai/gpt-5.6-luna", // cost-efficient model
  "enabled_providers": ["openai", "amazon-bedrock"],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.6-terra": {
          "options": {
            "textVerbosity": "low" // keep routine responses concise
          }
        }
      }
    },
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "bedrock"
      }
    }
  },
  "default_agent": "plan",
  "autoupdate": false,
  "share": "disabled",
  "plugin": ["@devtheops/opencode-plugin-otel@1.2.0"],
  "agent": {
    // Built-in primary agents
    "compaction": {
      "model": "openai/gpt-5.6-sol", // flagship model
      "reasoningEffort": "medium",
      "textVerbosity": "high"
    },
    // Built-in subagents
    "general": {
      "model": "openai/gpt-5.6-terra", // balanced model
      "reasoningEffort": "medium",
      "textVerbosity": "high"
    },
    "explore": {
      "model": "openai/gpt-5.6-terra", // balanced model
      "reasoningEffort": "medium",
      "textVerbosity": "high"
    }
  },
  "permission": {
    "external_directory": {
      "~/Workspaces/localhost/tmp/opencode-playground/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.local/share/rtk/tee/**": "allow"
    },
    "edit": {
      "~/.config/opencode/**": "deny"
    },
    "bash": {
      "*": "ask",
      "rm *": "deny", // NOTE: use trash command
      "* --help": "allow",
      "* --version": "allow",
      "ctx7 library *": "allow",
      "ctx7 docs *": "allow",
      "man *": "allow",
      "chezmoi managed": "allow",
      "chezmoi status": "allow",
      "chezmoi diff": "allow",
      "semble search *": "allow",
      "semble find-related *": "allow",
      "defuddle parse *": "allow",
      "markitdown *": "allow",
      "agent-browser skills get core": "allow",
      "hunk session list": "allow",
      "hunk session list *": "allow",
      "hunk session review *": "allow",
      "hunk session get *": "allow",
      "hunk session comment add *": "allow",
      "hunk session comment apply *": "allow",
      "hunk session comment list *": "allow",
      "herdr pane": "allow",
      "herdr pane current --current": "allow",
      "herdr pane list": "allow",
      "herdr pane read *": "allow",
      "herdr pane get *": "allow",
      "herdr status": "allow",
      "herdr workspace list": "allow",
      "herdr workspace list *": "allow",
      "herdr tab list": "allow",
      "herdr tab list *": "allow",
      "herdr pane layout *": "allow",
      "herdr pane process-info *": "allow",
      "herdr pane neighbor *": "allow",
      "herdr pane edges *": "allow",
      "herdr agent list": "allow",
      "herdr agent list *": "allow",
      "herdr agent get *": "allow",
      "herdr agent read *": "allow",
      "herdr agent explain *": "allow",
      "herdr integration status": "allow",
      "opencode session list": "allow",
      "opencode session list *": "allow",
      "opencode export *": "allow",
      "opencode export *>*": "ask",
      "opencode export *||*": "ask",
      "opencode export *|*": "ask",
      "opencode export *&&*": "ask",
      "opencode export *&*": "ask",
      "opencode export *;*": "ask",
      "opencode export *$(*": "ask",
      "opencode export *`*": "ask",
      "opencode debug`*": "ask",
      // File discovery and search
      "rtk ls": "allow",
      "rtk ls *": "allow",
      "RTK_DISABLED=1 ls": "allow",
      "RTK_DISABLED=1 ls *": "allow",
      "rtk grep *": "allow",
      "RTK_DISABLED=1 grep *": "allow",
      "rg *": "allow",
      "rtk find": "allow",
      "rtk find *": "allow",
      "rtk find *-exec*": "ask",
      "rtk find *-delete*": "ask",
      "RTK_DISABLED=1 find": "allow",
      "RTK_DISABLED=1 find *": "allow",
      "RTK_DISABLED=1 find *-exec*": "ask",
      "RTK_DISABLED=1 find *-delete*": "ask",
      "fd": "allow",
      "fd *": "allow",
      "test *": "allow",
      "stat *": "allow",
      // File reading and comparison
      "rtk read *": "allow",
      "RTK_DISABLED=1 cat *": "allow",
      "RTK_DISABLED=1 head": "allow",
      "RTK_DISABLED=1 head *": "allow",
      "RTK_DISABLED=1 tail": "allow",
      "RTK_DISABLED=1 tail *": "allow",
      "pwd": "allow",
      "realpath *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "sed *-i*": "ask",
      "col *": "allow",
      "rtk diff *": "allow",
      "RTK_DISABLED=1 diff *": "allow",
      // Git inspection
      "rtk git -C*": "deny",
      "RTK_DISABLED=1 git -C*": "deny",
      "git -C*": "deny",
      "rtk git branch": "allow",
      "rtk git branch *": "allow",
      "rtk git branch *-d*": "ask",
      "rtk git branch *-m*": "ask",
      "RTK_DISABLED=1 git branch": "allow",
      "RTK_DISABLED=1 git branch *": "allow",
      "RTK_DISABLED=1 git branch *-d*": "ask",
      "RTK_DISABLED=1 git branch *-m*": "ask",
      "git blame *": "allow",
      "git grep *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git ls-remote *": "allow",
      "git ls-tree *": "allow",
      "rtk git show": "allow",
      "rtk git show *": "allow",
      "RTK_DISABLED=1 git show": "allow",
      "RTK_DISABLED=1 git show *": "allow",
      "git show-ref *": "allow",
      "rtk git status": "allow",
      "rtk git status *": "allow",
      "RTK_DISABLED=1 git status": "allow",
      "RTK_DISABLED=1 git status *": "allow",
      "rtk git diff": "allow",
      "rtk git diff *": "allow",
      "RTK_DISABLED=1 git diff": "allow",
      "RTK_DISABLED=1 git diff *": "allow",
      "rtk git log": "allow",
      "rtk git log *": "allow",
      "RTK_DISABLED=1 git log": "allow",
      "RTK_DISABLED=1 git log *": "allow",
      "git shortlog": "allow",
      "git shortlog *": "allow",
      "git symbolic-ref *": "allow",
      "git rev-parse *": "allow",
      "git rev-list *": "allow",
      "git remote -v": "allow",
      "git remote show": "allow",
      "git remote show *": "allow",
      "rtk git merge-base *": "allow",
      "RTK_DISABLED=1 git merge-base *": "allow",
      // Formatter & Linter
      "rtk go -C*": "deny",
      "RTK_DISABLED=1 go -C*": "deny",
      "go -C*": "deny",
      "go fmt *": "allow",
      "go list *": "allow",
      "rtk go test *": "allow",
      "RTK_DISABLED=1 go test *": "allow",
      "gofmt *": "allow",
      "gofumpt *": "allow",
      "na exec vitest *": "allow",
      "na exec prettier *": "allow",
      "na exec biome *": "allow",
      "nr test": "allow",
      "nr format": "allow",
      "nr fmt": "allow",
      "nl *": "allow",
      "sqlfluff fix *": "allow",
      "sqlfluff lint *": "allow",
      "rtk prettier --check *": "allow",
      "RTK_DISABLED=1 prettier --check *": "allow",
      "pre-commit run *": "allow",
      // AWS read operations
      "rtk aws * get-* *": "allow",
      "rtk aws * describe-* *": "allow",
      "rtk aws * list-* *": "allow",
      "rtk aws logs start-query *": "allow",
      "rtk aws logs filter-log-events *": "allow",
      "RTK_DISABLED=1 aws * get-* *": "allow",
      "RTK_DISABLED=1 aws * describe-* *": "allow",
      "RTK_DISABLED=1 aws * list-* *": "allow",
      "RTK_DISABLED=1 aws logs start-query *": "allow",
      "RTK_DISABLED=1 aws logs filter-log-events *": "allow",
      // Docker Compose inspection
      "rtk docker compose ps": "allow",
      "rtk docker compose logs *": "allow",
      "RTK_DISABLED=1 docker compose ps": "allow",
      "RTK_DISABLED=1 docker compose logs *": "allow",
      // Kubernetes inspection
      "rtk kubectl --context*": "deny",
      "rtk kubectl --namespace*": "deny",
      "rtk kubectl -n*": "deny",
      "RTK_DISABLED=1 kubectl --context*": "deny",
      "RTK_DISABLED=1 kubectl --namespace*": "deny",
      "RTK_DISABLED=1 kubectl -n*": "deny",
      "kubectl --context*": "deny",
      "kubectl --namespace*": "deny",
      "kubectl -n*": "deny",
      "kubectl auth whoami *": "allow",
      "kubectl auth can-i *": "allow",
      "kubectl config current-context": "allow",
      "rtk kubectl logs *": "allow",
      "rtk kubectl get *": "allow",
      "RTK_DISABLED=1 kubectl logs *": "allow",
      "RTK_DISABLED=1 kubectl get *": "allow",
      "kubectl explain *": "allow",
      "kubectl describe *": "allow",
      "kubectl rollout history *": "allow",
      "rtk helm --kube-context*": "deny",
      "rtk helm --namespace*": "deny",
      "rtk helm -n*": "deny",
      "RTK_DISABLED=1 helm --kube-context*": "deny",
      "RTK_DISABLED=1 helm --namespace*": "deny",
      "RTK_DISABLED=1 helm -n*": "deny",
      "helm --kube-context*": "deny",
      "helm --namespace*": "deny",
      "helm -n*": "deny",
      "helm list *": "allow",
      "helm show *": "allow",
      "helm template *": "allow",
      "rtk helmfile --kube-context*": "deny",
      "rtk helmfile --namespace*": "deny",
      "rtk helmfile -n*": "deny",
      "RTK_DISABLED=1 helmfile --kube-context*": "deny",
      "RTK_DISABLED=1 helmfile --namespace*": "deny",
      "RTK_DISABLED=1 helmfile -n*": "deny",
      "helmfile --kube-context*": "deny",
      "helmfile --namespace*": "deny",
      "helmfile -n*": "deny",
      "helmfile template": "allow",
      "helmfile template *": "allow",
      "rtk terraform -chdir*": "deny",
      "RTK_DISABLED=1 terraform -chdir*": "deny",
      "terraform -chdir*": "deny",
      "terraform init -backend=false": "allow",
      "terragrunt init -backend=false": "allow",
      "terragrunt validate": "allow",
      "terragrunt validate *": "allow",
      "terragrunt output": "allow",
      "terragrunt output *": "allow",
      "terragrunt state list": "allow",
      "terragrunt state list *": "allow",
      "terragrunt show": "allow",
      "terragrunt show *": "allow",
      "terraform state list": "allow",
      "terraform state list *": "allow",
      "terraform show": "allow",
      "terraform show *": "allow",
      "terraform console": "allow",
      "terraform console *": "allow",
      "terraform fmt": "allow",
      "terraform fmt *": "allow",
      "terraform test": "allow",
      "terraform test *": "allow",
      "terraform validate": "allow",
      "terraform validate *": "allow",
      "terraform output": "allow",
      "terraform output *": "allow",
      "terraform-docs *": "allow",
      "tflint": "allow",
      "tflint *": "allow",
      "rumdl *": "allow",
      "gh auth status": "allow",
      "gh auth status *": "allow",
      "gh auth status *--show-token*": "deny",
      "rtk gh issue list": "allow",
      "rtk gh issue list *": "allow",
      "rtk gh issue view *": "allow",
      "RTK_DISABLED=1 gh issue list": "allow",
      "RTK_DISABLED=1 gh issue list *": "allow",
      "RTK_DISABLED=1 gh issue view *": "allow",
      "rtk gh pr list": "allow",
      "rtk gh pr list *": "allow",
      "rtk gh pr view": "allow",
      "rtk gh pr view *": "allow",
      "rtk gh pr diff": "allow",
      "rtk gh pr diff *": "allow",
      "rtk gh pr checks": "allow",
      "rtk gh pr checks *": "allow",
      "RTK_DISABLED=1 gh pr list": "allow",
      "RTK_DISABLED=1 gh pr list *": "allow",
      "RTK_DISABLED=1 gh pr view": "allow",
      "RTK_DISABLED=1 gh pr view *": "allow",
      "RTK_DISABLED=1 gh pr diff": "allow",
      "RTK_DISABLED=1 gh pr diff *": "allow",
      "RTK_DISABLED=1 gh pr checks": "allow",
      "RTK_DISABLED=1 gh pr checks *": "allow",
      "gh status": "allow",
      "gh status *": "allow",
      "rtk gh repo view": "allow",
      "rtk gh repo view *": "allow",
      "rtk gh repo list": "allow",
      "rtk gh repo list *": "allow",
      "RTK_DISABLED=1 gh repo view": "allow",
      "RTK_DISABLED=1 gh repo view *": "allow",
      "RTK_DISABLED=1 gh repo list": "allow",
      "RTK_DISABLED=1 gh repo list *": "allow",
      "rtk gh run list": "allow",
      "rtk gh run list *": "allow",
      "rtk gh run view": "allow",
      "rtk gh run view *": "allow",
      "RTK_DISABLED=1 gh run list": "allow",
      "RTK_DISABLED=1 gh run list *": "allow",
      "RTK_DISABLED=1 gh run view": "allow",
      "RTK_DISABLED=1 gh run view *": "allow",
      "gh workflow list": "allow",
      "gh workflow list *": "allow",
      "gh workflow view": "allow",
      "gh workflow view *": "allow",
      "gh release list": "allow",
      "gh release list *": "allow",
      "gh release view": "allow",
      "gh release view *": "allow",
      "gh search issues *": "allow",
      "gh search prs *": "allow",
      "gh search repos *": "allow",
      "gh api *": "allow",
      "gh api *-f*": "ask",
      "gh api *--raw-field*": "ask",
      "gh api *-F*": "ask",
      "gh api *--field*": "ask",
      "gh api *--input*": "ask",
      "gh api *--method*": "ask",
      "gh api *-X*": "ask",
      "gh api graphql*": "ask",
      "gh api * graphql*": "ask",
      "gh api *--method GET*": "allow",
      "gh api *--method=GET*": "allow",
      "gh api *-X GET*": "allow",
      "gh api *-XGET*": "allow",
      "glab auth status": "allow",
      "glab ci trace *": "allow",
      "glab ci status": "allow",
      "glab issue view *": "allow",
      "glab mr view": "allow",
      "glab mr view *": "allow",
      "glab mr diff": "allow",
      "glab mr diff *": "allow",
      "glab api *": "allow",
      "glab api *-f*": "ask",
      "glab api *--raw-field*": "ask",
      "glab api *-F*": "ask",
      "glab api *--field*": "ask",
      "glab api *--form*": "ask",
      "glab api *--input*": "ask",
      "glab api *--method*": "ask",
      "glab api *-X*": "ask",
      "glab api graphql*": "ask",
      "glab api * graphql*": "ask",
      "glab api *--method GET*": "allow",
      "glab api *--method=GET*": "allow",
      "glab api *-X GET*": "allow",
      "glab api *-XGET*": "allow",
      "hyprctl monitors": "allow",
      "hyprctl clients": "allow",
      "journalctl *": "allow",
      "journalctl *--vacuum-time*": "ask",
      "journalctl *--vacuum-size*": "ask",
      "journalctl *--rotate*": "ask",
      "systemctl cat *": "allow",
      "systemctl --user cat *": "allow",
      "systemctl status *": "allow",
      "systemctl --user status *": "allow",
      "systemctl show *": "allow",
      "systemctl --user show *": "allow",
      "systemctl list-units *": "allow",
      "systemctl --user list-units *": "allow",
      "systemctl list-unit-files *": "allow",
      "systemctl --user list-unit-files *": "allow",
      "systemctl list-dependencies *": "allow",
      "systemctl --user list-dependencies *": "allow",
      "systemctl is-active *": "allow",
      "systemctl --user is-active *": "allow",
      "systemctl is-enabled *": "allow",
      "systemctl --user is-enabled *": "allow",
      "systemctl is-failed *": "allow",
      "systemctl --user is-failed *": "allow",
      // Output measurement
      "jq": "allow",
      "jq *": "allow",
      "rtk wc": "allow",
      "rtk wc *": "allow",
      "RTK_DISABLED=1 wc": "allow",
      "RTK_DISABLED=1 wc *": "allow",
      "sort": "allow",
      "uniq": "allow",
      "date": "allow",
      "date *": "allow",
      "command -v *": "allow",
      "which *": "allow",
      "mise which *": "allow"
    }
  },
  "lsp": true,
  "formatter": {
    "rumdl-markdown": {
      "command": ["rumdl", "fmt", "$FILE"],
      "extensions": [".md"]
    },
    // NOTE: run prettier even without package.json
    //       https://github.com/anomalyco/opencode/blob/v1.14.46/packages/opencode/src/format/formatter.ts#L37-L84
    "prettier-jsonc": {
      "command": ["prettier", "--trailing-comma", "none", "--write", "$FILE"],
      "extensions": [".jsonc"]
    },
    "yamlfmt": {
      "command": ["yamlfmt", "$FILE"],
      "extensions": [".yml", ".yaml"]
    },
    "stylua": {
      "command": ["stylua", "$FILE"],
      "extensions": [".lua"]
    }
  },
  "mcp": {
    "mcp_server_terraform": {
      "enabled": true,
      "type": "local",
      "command": ["terraform-mcp-server"]
    },
    // NOTE: github-mcp-server not support Dynamic Client Registration
    //       https://github.com/github/github-mcp-server/issues/1396#issuecomment-3895920244
    //
    // ```sh
    // gh auth token |
    //   gopass insert envs/github-mcp-server/GITHUB_PERSONAL_ACCESS_TOKEN
    // ```
    "mcp_server_github": {
      "enabled": true,
      "type": "local",
      "command": [
        "gopass",
        "env",
        "envs/github-mcp-server",
        "github-mcp-server",
        "stdio",
        "--read-only"
      ]
    },
    "mcp_server_aws_n4vysh_stg": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-proxy-for-aws",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--disable-telemetry"
      ],
      "environment": {
        "AWS_PROFILE": "n4vysh-stg",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    "mcp_server_aws_n4vysh_prod": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-proxy-for-aws",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--disable-telemetry"
      ],
      "environment": {
        "AWS_PROFILE": "n4vysh-prod",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    "mcp_server_aws_n4vysh_common": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-proxy-for-aws",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--disable-telemetry"
      ],
      "environment": {
        "AWS_PROFILE": "n4vysh-common",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    "mcp_server_kubernetes_kind_sandbox": {
      "enabled": false,
      "type": "local",
      "command": ["kubernetes-mcp-server", "--read-only"],
      "environment": {
        "KUBECONFIG": "{env:HOME}/.kube/configs/kind-sandbox.yaml"
      }
    },
    // ```sh
    // gopass insert envs/mcp-grafana/n4vysh/GRAFANA_SERVICE_ACCOUNT_TOKEN
    // ```
    "mcp_server_grafana_n4vysh": {
      "enabled": false,
      "type": "local",
      "command": [
        "gopass",
        "env",
        "envs/mcp-grafana/n4vysh",
        "mcp-grafana",
        "--disable-write",
        "-t",
        "stdio"
      ],
      "environment": {
        "GRAFANA_ORG_ID": "0",
        "GRAFANA_URL": "https://n4vysh.grafana.net"
      }
    }
  }
}
