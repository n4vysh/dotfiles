      "helmfile template *": "allow",
      "terraform init -backend=false": "allow",
      "terragrunt init -backend=false": "allow",
      "terragrunt validate": "allow",
      "terragrunt validate *": "allow",
      "terragrunt output": "allow",
      "terragrunt output *": "allow",
      "terragrunt state list": "allow",
      "terragrunt state list *": "allow",
      "terragrunt show": "allow",
      "terragrunt show *": "allow",
      "terraform state list": "allow",
      "terraform state list *": "allow",
      "terraform show": "allow",
      "terraform show *": "allow",
      "terraform console": "allow",
      "terraform console *": "allow",
      "terraform fmt": "allow",
      "terraform fmt *": "allow",
      "terraform test": "allow",
      "terraform test *": "allow",
      "terraform validate": "allow",
      "terraform validate *": "allow",
      "terraform output": "allow",
      "terraform output *": "allow",
      "terraform-docs *": "allow",
      "tflint": "allow",
      "tflint *": "allow",
      "markdownlint-cli2 *": "allow",
      "gh auth status": "allow",
      "gh auth status *": "allow",
      "gh auth status *--show-token*": "deny",
      "gh issue list": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh pr list": "allow",
      "gh pr list *": "allow",
      "gh pr view": "allow",
      "gh pr view *": "allow",
      "gh pr diff": "allow",
      "gh pr diff *": "allow",
      "gh pr checks": "allow",
      "gh pr checks *": "allow",
      "gh status": "allow",
      "gh status *": "allow",
      "gh repo view": "allow",
      "gh repo view *": "allow",
      "gh repo list": "allow",
      "gh repo list *": "allow",
      "gh run list": "allow",
      "gh run list *": "allow",
      "gh run view": "allow",
      "gh run view *": "allow",
      "gh workflow list": "allow",
      "gh workflow list *": "allow",
      "gh workflow view": "allow",
      "gh workflow view *": "allow",
      "gh release list": "allow",
      "gh release list *": "allow",
      "gh release view": "allow",
      "gh release view *": "allow",
      "gh search issues *": "allow",
      "gh search prs *": "allow",
      "gh search repos *": "allow",
      "gh api *": "allow",
      "gh api *-f*": "ask",
      "gh api *--raw-field*": "ask",
      "gh api *-F*": "ask",
      "gh api *--field*": "ask",
      "gh api *--input*": "ask",
      "gh api *--method*": "ask",
      "gh api *-X*": "ask",
      "gh api graphql*": "ask",
      "gh api * graphql*": "ask",
      "gh api *--method GET*": "allow",
      "gh api *--method=GET*": "allow",
      "gh api *-X GET*": "allow",
      "gh api *-XGET*": "allow",
      "glab auth status": "allow",
      "glab ci trace *": "allow",
      "glab ci status": "allow",
      "glab issue view *": "allow",
      "glab mr view": "allow",
      "glab mr view *": "allow",
      "glab mr diff": "allow",
      "glab mr diff *": "allow",
      "glab api *": "allow",
      "glab api *-f*": "ask",
      "glab api *--raw-field*": "ask",
      "glab api *-F*": "ask",
      "glab api *--field*": "ask",
      "glab api *--form*": "ask",
      "glab api *--input*": "ask",
      "glab api *--method*": "ask",
      "glab api *-X*": "ask",
      "glab api graphql*": "ask",
      "glab api * graphql*": "ask",
      "glab api *--method GET*": "allow",
      "glab api *--method=GET*": "allow",
      "glab api *-X GET*": "allow",
      "glab api *-XGET*": "allow",
      "hyprctl monitors": "allow",
      "hyprctl clients": "allow",
      "journalctl *": "allow",
      "journalctl *--vacuum-time*": "ask",
      "journalctl *--vacuum-size*": "ask",
      "journalctl *--rotate*": "ask",
      "systemctl cat *": "allow",
      "systemctl --user cat *": "allow",
      "systemctl status *": "allow",
      "systemctl --user status *": "allow",
      "systemctl show *": "allow",
      "systemctl --user show *": "allow",
      "systemctl list-units *": "allow",
      "systemctl --user list-units *": "allow",
      "systemctl list-unit-files *": "allow",
      "systemctl --user list-unit-files *": "allow",
      "systemctl list-dependencies *": "allow",
      "systemctl --user list-dependencies *": "allow",
      "systemctl is-active *": "allow",
      "systemctl --user is-active *": "allow",
      "systemctl is-enabled *": "allow",
      "systemctl --user is-enabled *": "allow",
      "systemctl is-failed *": "allow",
      "systemctl --user is-failed *": "allow",
      "jq": "allow",
      "jq *": "allow",
      "rtk wc": "allow",
      "rtk wc *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "sort": "allow",
      "uniq": "allow",
      "date": "allow",
      "date *": "allow",
      "command -v *": "allow",
      "which *": "allow"
    }
  },
  "lsp": true,
  "formatter": {
    // NOTE: run prettier even without package.json
    //       https://github.com/anomalyco/opencode/blob/v1.14.46/packages/opencode/src/format/formatter.ts#L37-L84
    "prettier-markdown": {
      "command": ["prettier", "--tab-width", "4", "--write", "$FILE"],
      "extensions": [".md"]
    },
    // NOTE: run prettier even without package.json
    //       https://github.com/anomalyco/opencode/blob/v1.14.46/packages/opencode/src/format/formatter.ts#L37-L84
    "prettier-jsonc": {
      "command": ["prettier", "--trailing-comma", "none", "--write", "$FILE"],
      "extensions": [".jsonc"]
    },
    "yamlfmt": {
      "command": ["yamlfmt", "$FILE"],
      "extensions": [".yml", ".yaml"]
    },
    "stylua": {
      "command": ["stylua", "$FILE"],
      "extensions": [".lua"]
    }
  },
  "mcp": {
    "aws-knowledge-mcp-server": {
      "enabled": true,
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "terraform-mcp-server": {
      "enabled": true,
      "type": "local",
      "command": ["terraform-mcp-server"]
    },
    // ```sh
    // opencode mcp auth context7-mcp-server
    // ```
    "context7-mcp-server": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth"
    },
    "grep-mcp-server": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    // NOTE: github-mcp-server not support Dynamic Client Registration
    //       https://github.com/github/github-mcp-server/issues/1396#issuecomment-3895920244
    //
    // ```sh
    // gh auth token |
    //   gopass insert envs/github-mcp-server/GITHUB_PERSONAL_ACCESS_TOKEN
    // ```
    "github-mcp-server": {
      "enabled": true,
      "type": "local",
      "command": [
        "gopass",
        "env",
        "envs/github-mcp-server",
        "github-mcp-server",
        "stdio",
        "--read-only"
      ]
    },
    "deepwiki-mcp-server": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "mdn-mcp-server": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.mdn.mozilla.net/",
      "headers": {
        "X-Moz-1st-Party-Data-Opt-Out": "1"
      }
    },
    "markitdown-mcp-server": {
      "enabled": true,
      "type": "local",
      "command": ["markitdown-mcp"]
    },
    "semgrep-mcp-server": {
      "enabled": true,
      "type": "local",
      "command": ["semgrep", "mcp"]
    },
    "aws-n4vysh-stg-mcp-server": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-proxy-for-aws",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--disable-telemetry"
      ],
      "environment": {
        "AWS_PROFILE": "n4vysh-stg",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    "aws-n4vysh-prod-mcp-server": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-proxy-for-aws",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--disable-telemetry"
      ],
      "environment": {
        "AWS_PROFILE": "n4vysh-prod",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    "aws-n4vysh-common-mcp-server": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-proxy-for-aws",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--disable-telemetry"
      ],
      "environment": {
        "AWS_PROFILE": "n4vysh-common",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    // ```sh
    // gopass insert envs/mcp-grafana/n4vysh/GRAFANA_SERVICE_ACCOUNT_TOKEN
    // ```
    "grafana-n4vysh-mcp-server": {
      "enabled": false,
      "type": "local",
      "command": [
        "gopass",
        "env",
        "envs/mcp-grafana/n4vysh",
        "mcp-grafana",
        "--disable-write",
        "-t",
        "stdio"
      ],
      "environment": {
        "GRAFANA_ORG_ID": "0",
        "GRAFANA_URL": "https://n4vysh.grafana.net"
      }
    }
    // "aws-example-dev-mcp-server": {
    //   "enabled": false,
    //   "type": "local",
    //   "command": [
    //     "mcp-proxy-for-aws",
    //     "https://aws-mcp.us-east-1.api.aws/mcp",
    //     "--disable-telemetry"
    //   ],
    //   "environment": {
    //     "AWS_PROFILE": "example-dev",
    //     "AWS_REGION": "ap-northeast-1"
    //   }
    // },
    // "kubernetes-example-dev-mcp-server": {
    //   "enabled": false,
    //   "type": "local",
    //   "command": [
    //     "kubernetes-mcp-server",
    //     "--read-only"
    //   ],
    //   "environment": {
    //     "KUBECONFIG": "{env:HOME}/.kube/configs/example-dev"
    //   }
    // },
    // // ```sh
    // // gopass insert envs/mcp-grafana/example-dev/GRAFANA_SERVICE_ACCOUNT_TOKEN
    // // ```
    // "grafana-example-dev-mcp-server": {
    //   "enabled": false,
    //   "type": "local",
    //   "command": [
    //     "gopass",
    //     "env",
    //     "envs/mcp-grafana/example-dev",
    //     "mcp-grafana",
    //     "--disable-write",
    //     "-t",
    //     "stdio"
    //   ],
    //   "environment": {
    //     "GRAFANA_ORG_ID": "0",
    //     "GRAFANA_URL": "https://example.com"
    //   }
    // },
  },
  "tools": {
    "aws-knowledge-mcp-server*": false,
    "terraform-mcp-server*": false,
    "context7-mcp-server*": false,
    "grep-mcp-server*": false,
    "github-mcp-server*": false,
    "deepwiki-mcp-server*": false,
    "mdn-mcp-server*": false,
    "markitdown-mcp-server*": false,
    "semgrep-mcp-server*": false,
    "aws-n4vysh-stg-mcp-server*": false,
    "aws-n4vysh-prod-mcp-server*": false,
    "aws-n4vysh-common-mcp-server*": false,
    "grafana-n4vysh-mcp-server*": false
    // "aws-example-dev-mcp-server*": false,
    // "kubernetes-example-dev-mcp-server*": false,
    // "grafana-example-dev-mcp-server*": false
  },
  "agent": {
    "aws-docs-expert": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Provides AWS official documents for designing, building, and operating workloads",
      "prompt": "Use aws-knowledge-mcp-server* tools",
      "tools": {
        "aws-knowledge-mcp-server*": true
      }
    },
    "terraform-expert": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Provides Terraform official documents for providers and modules",
      "prompt": "Use terraform-mcp-server* tools",
      "tools": {
        "terraform-mcp-server*": true
      }
    },
    "context7": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Provides up-to-date documentation for latest library versions, best practices, and correct syntax",
      "prompt": "Use context7-mcp-server* tools",
      "tools": {
        "context7-mcp-server*": true
      }
    },
    "grep.app": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Search for code, files, and paths across GitHub repositories",
      "prompt": "Use grep-mcp-server* tools",
      "tools": {
        "grep-mcp-server*": true
      }
    },
    "github": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Read repositories, code files, issues, and PRs",
      "prompt": "Use github-mcp-server* tools",
      "tools": {
        "github-mcp-server*": true
      }
    },
    "deepwiki": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Provides DeepWiki’s public repository documentation and search capabilities",
      "prompt": "Use deepwiki-mcp-server* tools",
      "tools": {
        "deepwiki-mcp-server*": true
      }
    },
    "mdn": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Provides MDN Web Docs search, documentation, and browser compatibility data",
      "prompt": "Use mdn-mcp-server* tools. Provide reliable, up-to-date web platform documentation and browser compatibility data from MDN Web Docs.",
      "tools": {
        "mdn-mcp-server*": true
      }
    },
    "markitdown": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Converts files, URLs, and data URIs to Markdown using MarkItDown",
      "prompt": "Use markitdown-mcp-server* tools. Convert supported file, http, https, and data URIs to Markdown. Be careful with untrusted URIs because MarkItDown can read local files and network resources accessible to the current user.",
      "tools": {
        "markitdown-mcp-server*": true
      }
    },
    "semgrep": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Runs semgrep security analysis for code, dependencies, and secrets",
      "prompt": "Use semgrep-mcp-server* tools. Run semgrep security analysis and report findings with file paths, severity, and remediation guidance.",
      "tools": {
        "semgrep-mcp-server*": true
      }
    },
    "aws-api-expert:n4vysh-stg": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Provides AWS API access for n4vysh-stg",
      "prompt": "Use aws-n4vysh-stg-mcp-server* tools. If unavailable, report that MCP server must be enabled before proceeding.",
      "tools": {
        "aws-n4vysh-stg-mcp-server*": true
      }
    },
    "aws-api-expert:n4vysh-prod": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Provides AWS API access for n4vysh-prod",
      "prompt": "Use aws-n4vysh-prod-mcp-server* tools. If unavailable, report that MCP server must be enabled before proceeding.",
      "tools": {
        "aws-n4vysh-prod-mcp-server*": true
      }
    },
    "aws-api-expert:n4vysh-common": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Provides AWS API access for n4vysh-common",
      "prompt": "Use aws-n4vysh-common-mcp-server* tools. If unavailable, report that MCP server must be enabled before proceeding.",
      "tools": {
        "aws-n4vysh-common-mcp-server*": true
      }
    },
    "grafana-expert:n4vysh": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "description": "Provides Grafana API access for n4vysh",
      "prompt": "Use grafana-n4vysh-mcp-server* tools. If unavailable, report that MCP server must be enabled before proceeding.",
      "tools": {
        "grafana-n4vysh-mcp-server*": true
      }
    }
