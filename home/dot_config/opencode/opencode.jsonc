{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5-fast",
  "small_model": "openai/gpt-5.4",
  "default_agent": "plan",
  "autoupdate": false,
  "share": "disabled",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git#v5.1.0",
    "@devtheops/opencode-plugin-otel@1.2.0"
  ],
  "permission": {
    "edit": "ask",
    "external_directory": {
      "~/Workspaces/localhost/tmp/opencode/**": "allow"
    },
    "bash": {
      "*": "ask",
      "* --help": "allow",
      "* --version": "allow",
      "man *": "allow",
      "chezmoi managed": "allow",
      "chezmoi status": "allow",
      "chezmoi diff": "allow",
      "semble search *": "allow",
      "semble find-related *": "allow",
      "defuddle parse *": "allow",
      "agent-browser skills get core": "allow",
      "rtk ls": "allow",
      "rtk ls *": "allow",
      "rtk grep *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "rtk find": "allow",
      "rtk find *": "allow",
      "rtk find *-exec*": "ask",
      "rtk find *-delete*": "ask",
      "find": "allow",
      "find *": "allow",
      "find *-exec*": "ask",
      "find *-delete*": "ask",
      "fd": "allow",
      "fd *": "allow",
      "test *": "allow",
      "stat *": "allow",
      "cat *": "allow",
      "rtk read *": "allow",
      "pwd": "allow",
      "realpath *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "sed *-i*": "ask",
      "col *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "rtk diff *": "allow",
      "rtk git branch": "allow",
      "rtk git branch *": "allow",
      "rtk git branch *-d*": "ask",
      "rtk git branch *-m*": "ask",
      "diff *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git branch *-d*": "ask",
      "git branch *-m*": "ask",
      "git blame *": "allow",
      "git grep *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git ls-remote *": "allow",
      "git ls-tree *": "allow",
      "rtk git show": "allow",
      "rtk git show *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git show-ref *": "allow",
      "rtk git status": "allow",
      "rtk git status *": "allow",
      "rtk git diff": "allow",
      "rtk git diff *": "allow",
      "rtk git log": "allow",
      "rtk git log *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git shortlog": "allow",
      "git shortlog *": "allow",
      "git symbolic-ref *": "allow",
      "git rev-parse *": "allow",
      "git rev-list *": "allow",
      "git remote -v": "allow",
      "git remote show": "allow",
      "git remote show *": "allow",
      "rtk git merge-base *": "allow",
      "git merge-base *": "allow",
      "go fmt *": "allow",
      "go list *": "allow",
      "rtk go test *": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "gofumpt *": "allow",
      "na exec vitest *": "allow",
      "na exec prettier *": "allow",
      "na exec biome *": "allow",
