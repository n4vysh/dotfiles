      "sqlfluff fix *": "allow",
      "sqlfluff lint *": "allow",
      "rtk aws * get-* *": "allow",
      "rtk aws * describe-* *": "allow",
      "rtk aws * list-* *": "allow",
      "rtk aws logs start-query *": "allow",
      "rtk aws logs filter-log-events *": "allow",
      "rtk docker compose ps": "allow",
      "rtk docker compose logs *": "allow",
      "aws * get-* *": "allow",
      "aws * describe-* *": "allow",
      "aws * list-* *": "allow",
      "aws logs start-query *": "allow",
      "aws logs filter-log-events *": "allow",
      "docker compose ps": "allow",
      "docker compose logs *": "allow",
      "kubectl auth whoami *": "allow",
      "kubectl auth can-i *": "allow",
