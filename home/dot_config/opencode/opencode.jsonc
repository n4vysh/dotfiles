{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "small_model": "openai/gpt-5.6-luna",
  "enabled_providers": ["openai", "amazon-bedrock"],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.6-terra": {
          "options": {
            "textVerbosity": "low"
          }
        }
      }
    },
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "bedrock"
      }
    }
  },
  "default_agent": "plan",
  "autoupdate": false,
  "share": "disabled",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git#v5.1.0",
    "@devtheops/opencode-plugin-otel@1.2.0"
  ],
  "agent": {
    // Built-in primary agents
    "compaction": {
      "model": "openai/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "textVerbosity": "high"
    },
    // Built-in subagents
    "general": {
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "medium",
      "textVerbosity": "high"
    },
    "explore": {
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "medium",
      "textVerbosity": "high"
    }
  },
  "permission": {
    "external_directory": {
      "~/Workspaces/localhost/tmp/opencode-playground/**": "allow",
      "~/.local/share/rtk/tee/**": "allow"
    },
    "bash": {
      "*": "ask",
      "rm *": "deny", // NOTE: use trash command
      "* --help": "allow",
      "* --version": "allow",
      "man *": "allow",
      "chezmoi managed": "allow",
      "chezmoi status": "allow",
      "chezmoi diff": "allow",
      "semble search *": "allow",
      "semble find-related *": "allow",
      "defuddle parse *": "allow",
      "agent-browser skills get core": "allow",
      "rtk ls": "allow",
      "rtk ls *": "allow",
      "rtk grep *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "rtk find": "allow",
      "rtk find *": "allow",
      "rtk find *-exec*": "ask",
      "rtk find *-delete*": "ask",
      "find": "allow",
      "find *": "allow",
      "find *-exec*": "ask",
      "find *-delete*": "ask",
      "fd": "allow",
      "fd *": "allow",
      "test *": "allow",
      "stat *": "allow",
      "cat *": "allow",
      "rtk read *": "allow",
      "pwd": "allow",
      "realpath *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "sed *-i*": "ask",
      "col *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "rtk diff *": "allow",
      "rtk git branch": "allow",
      "rtk git branch *": "allow",
      "rtk git branch *-d*": "ask",
      "rtk git branch *-m*": "ask",
      "diff *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git branch *-d*": "ask",
      "git branch *-m*": "ask",
      "git blame *": "allow",
      "git grep *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git ls-remote *": "allow",
      "git ls-tree *": "allow",
      "rtk git show": "allow",
      "rtk git show *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git show-ref *": "allow",
      "rtk git status": "allow",
      "rtk git status *": "allow",
      "rtk git diff": "allow",
      "rtk git diff *": "allow",
      "rtk git log": "allow",
      "rtk git log *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git shortlog": "allow",
      "git shortlog *": "allow",
      "git symbolic-ref *": "allow",
      "git rev-parse *": "allow",
      "git rev-list *": "allow",
      "git remote -v": "allow",
      "git remote show": "allow",
      "git remote show *": "allow",
      "rtk git merge-base *": "allow",
      "git merge-base *": "allow",
      "go fmt *": "allow",
      "go list *": "allow",
      "rtk go test *": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "gofumpt *": "allow",
      "na exec vitest *": "allow",
      "na exec prettier *": "allow",
      "na exec biome *": "allow",
      "nr test": "allow",
      "nr format": "allow",
      "nr fmt": "allow",
      "nl *": "allow",
      "sqlfluff fix *": "allow",
      "sqlfluff lint *": "allow",
      "rtk aws * get-* *": "allow",
      "rtk aws * describe-* *": "allow",
      "rtk aws * list-* *": "allow",
      "rtk aws logs start-query *": "allow",
      "rtk aws logs filter-log-events *": "allow",
      "rtk docker compose ps": "allow",
      "rtk docker compose logs *": "allow",
      "aws * get-* *": "allow",
      "aws * describe-* *": "allow",
      "aws * list-* *": "allow",
      "aws logs start-query *": "allow",
      "aws logs filter-log-events *": "allow",
      "docker compose ps": "allow",
      "docker compose logs *": "allow",
      "kubectl auth whoami *": "allow",
      "kubectl auth can-i *": "allow",
      "kubectl config current-context": "allow",
      "rtk kubectl logs *": "allow",
      "kubectl logs *": "allow",
      "kubectl explain *": "allow",
      "rtk kubectl get *": "allow",
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl rollout history *": "allow",
      "helm list *": "allow",
      "helm show *": "allow",
      "helm template *": "allow",
      "helmfile template": "allow",
      "helmfile template *": "allow",
      "terraform init -backend=false": "allow",
      "terragrunt init -backend=false": "allow",
      "terragrunt validate": "allow",
      "terragrunt validate *": "allow",
      "terragrunt output": "allow",
      "terragrunt output *": "allow",
      "terragrunt state list": "allow",
      "terragrunt state list *": "allow",
      "terragrunt show": "allow",
      "terragrunt show *": "allow",
      "terraform state list": "allow",
      "terraform state list *": "allow",
      "terraform show": "allow",
      "terraform show *": "allow",
      "terraform console": "allow",
      "terraform console *": "allow",
      "terraform fmt": "allow",
      "terraform fmt *": "allow",
      "terraform test": "allow",
      "terraform test *": "allow",
      "terraform validate": "allow",
      "terraform validate *": "allow",
      "terraform output": "allow",
      "terraform output *": "allow",
      "terraform-docs *": "allow",
      "tflint": "allow",
      "tflint *": "allow",
      "rumdl *": "allow",
      "gh auth status": "allow",
      "gh auth status *": "allow",
      "gh auth status *--show-token*": "deny",
      "gh issue list": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh pr list": "allow",
      "gh pr list *": "allow",
      "gh pr view": "allow",
      "gh pr view *": "allow",
      "gh pr diff": "allow",
      "gh pr diff *": "allow",
      "gh pr checks": "allow",
      "gh pr checks *": "allow",
      "gh status": "allow",
      "gh status *": "allow",
      "gh repo view": "allow",
      "gh repo view *": "allow",
      "gh repo list": "allow",
      "gh repo list *": "allow",
      "gh run list": "allow",
      "gh run list *": "allow",
      "gh run view": "allow",
      "gh run view *": "allow",
      "gh workflow list": "allow",
      "gh workflow list *": "allow",
      "gh workflow view": "allow",
      "gh workflow view *": "allow",
      "gh release list": "allow",
      "gh release list *": "allow",
      "gh release view": "allow",
      "gh release view *": "allow",
      "gh search issues *": "allow",
      "gh search prs *": "allow",
      "gh search repos *": "allow",
      "gh api *": "allow",
      "gh api *-f*": "ask",
      "gh api *--raw-field*": "ask",
      "gh api *-F*": "ask",
      "gh api *--field*": "ask",
      "gh api *--input*": "ask",
      "gh api *--method*": "ask",
      "gh api *-X*": "ask",
      "gh api graphql*": "ask",
      "gh api * graphql*": "ask",
      "gh api *--method GET*": "allow",
      "gh api *--method=GET*": "allow",
      "gh api *-X GET*": "allow",
      "gh api *-XGET*": "allow",
      "glab auth status": "allow",
      "glab ci trace *": "allow",
      "glab ci status": "allow",
      "glab issue view *": "allow",
      "glab mr view": "allow",
      "glab mr view *": "allow",
      "glab mr diff": "allow",
      "glab mr diff *": "allow",
      "glab api *": "allow",
      "glab api *-f*": "ask",
      "glab api *--raw-field*": "ask",
      "glab api *-F*": "ask",
      "glab api *--field*": "ask",
      "glab api *--form*": "ask",
      "glab api *--input*": "ask",
      "glab api *--method*": "ask",
      "glab api *-X*": "ask",
      "glab api graphql*": "ask",
      "glab api * graphql*": "ask",
      "glab api *--method GET*": "allow",
      "glab api *--method=GET*": "allow",
      "glab api *-X GET*": "allow",
      "glab api *-XGET*": "allow",
      "hyprctl monitors": "allow",
      "hyprctl clients": "allow",
      "journalctl *": "allow",
      "journalctl *--vacuum-time*": "ask",
      "journalctl *--vacuum-size*": "ask",
      "journalctl *--rotate*": "ask",
      "systemctl cat *": "allow",
      "systemctl --user cat *": "allow",
      "systemctl status *": "allow",
      "systemctl --user status *": "allow",
      "systemctl show *": "allow",
      "systemctl --user show *": "allow",
      "systemctl list-units *": "allow",
      "systemctl --user list-units *": "allow",
      "systemctl list-unit-files *": "allow",
      "systemctl --user list-unit-files *": "allow",
      "systemctl list-dependencies *": "allow",
      "systemctl --user list-dependencies *": "allow",
      "systemctl is-active *": "allow",
      "systemctl --user is-active *": "allow",
      "systemctl is-enabled *": "allow",
      "systemctl --user is-enabled *": "allow",
      "systemctl is-failed *": "allow",
      "systemctl --user is-failed *": "allow",
      "jq": "allow",
      "jq *": "allow",
      "rtk wc": "allow",
      "rtk wc *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "sort": "allow",
      "uniq": "allow",
      "date": "allow",
      "date *": "allow",
      "command -v *": "allow",
      "which *": "allow"
    },
    "mcp_server_*": "deny"
  },
  "lsp": true,
  "formatter": {
    "rumdl-markdown": {
      "command": ["rumdl", "fmt", "$FILE"],
      "extensions": [".md"]
    },
    // NOTE: run prettier even without package.json
    //       https://github.com/anomalyco/opencode/blob/v1.14.46/packages/opencode/src/format/formatter.ts#L37-L84
    "prettier-jsonc": {
      "command": ["prettier", "--trailing-comma", "none", "--write", "$FILE"],
      "extensions": [".jsonc"]
    },
    "yamlfmt": {
      "command": ["yamlfmt", "$FILE"],
      "extensions": [".yml", ".yaml"]
    },
    "stylua": {
      "command": ["stylua", "$FILE"],
      "extensions": [".lua"]
    }
  },
  "mcp": {
    "mcp_server_aws_knowledge": {
      "enabled": true,
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "mcp_server_terraform": {
      "enabled": true,
      "type": "local",
      "command": ["terraform-mcp-server"]
    },
    // ```sh
    // opencode mcp auth mcp_server_context7
    // ```
    "mcp_server_context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth"
    },
    "mcp_server_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    // NOTE: github-mcp-server not support Dynamic Client Registration
    //       https://github.com/github/github-mcp-server/issues/1396#issuecomment-3895920244
    //
    // ```sh
    // gh auth token |
    //   gopass insert envs/github-mcp-server/GITHUB_PERSONAL_ACCESS_TOKEN
    // ```
    "mcp_server_github": {
      "enabled": true,
      "type": "local",
      "command": [
        "gopass",
        "env",
        "envs/github-mcp-server",
        "github-mcp-server",
        "stdio",
        "--read-only"
      ]
    },
    "mcp_server_deepwiki": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "mcp_server_markitdown": {
      "enabled": true,
      "type": "local",
      "command": ["markitdown-mcp"]
    },
    "mcp_server_aws_n4vysh_stg": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-proxy-for-aws",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--disable-telemetry"
      ],
      "environment": {
        "AWS_PROFILE": "n4vysh-stg",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    "mcp_server_aws_n4vysh_prod": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-proxy-for-aws",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--disable-telemetry"
      ],
      "environment": {
        "AWS_PROFILE": "n4vysh-prod",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    "mcp_server_aws_n4vysh_common": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-proxy-for-aws",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--disable-telemetry"
      ],
      "environment": {
        "AWS_PROFILE": "n4vysh-common",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    "mcp_server_kubernetes_kind_sandbox": {
      "enabled": false,
      "type": "local",
      "command": ["kubernetes-mcp-server", "--read-only"],
      "environment": {
        "KUBECONFIG": "{env:HOME}/.kube/configs/kind-sandbox.yaml"
      }
    },
    // ```sh
    // gopass insert envs/mcp-grafana/n4vysh/GRAFANA_SERVICE_ACCOUNT_TOKEN
    // ```
    "mcp_server_grafana_n4vysh": {
      "enabled": false,
      "type": "local",
      "command": [
        "gopass",
        "env",
        "envs/mcp-grafana/n4vysh",
        "mcp-grafana",
        "--disable-write",
        "-t",
        "stdio"
      ],
      "environment": {
        "GRAFANA_ORG_ID": "0",
        "GRAFANA_URL": "https://n4vysh.grafana.net"
      }
    }
  }
}
